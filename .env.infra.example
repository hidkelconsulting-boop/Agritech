# Use this when running Postgres + Redis with docker compose
# API
API_PORT=4000
JWT_SECRET=change-me-in-production
APP_ENV=development
DATABASE_URL="postgresql://agritech:agritech@localhost:5432/agritech?schema=public"
REDIS_URL="redis://localhost:6379"
UPLOADS_DIR="./uploads"

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
WEB_APP_URL=https://your-app.fly.dev

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000

# S3 / Cloudflare R2 object storage
# Leave blank in dev to fall back to local disk (./uploads)
S3_BUCKET=your-bucket-name
S3_REGION=auto
# For Cloudflare R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# For AWS S3: leave blank (SDK uses region-based endpoint automatically)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
